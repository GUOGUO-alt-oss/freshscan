<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive health data from cloud backup -->
        <exclude domain="database" path="fruit_freshness.db"/>
        <exclude domain="datastore" path="taste_profile"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive health data from device transfer -->
        <exclude domain="database" path="fruit_freshness.db"/>
        <exclude domain="datastore" path="taste_profile"/>
    </device-transfer>
</data-extraction-rules>